<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:id="@+id/main"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	tools:context=".MainActivity">

	<TextView
		android:layout_width="285dp"
		android:layout_height="176dp"
		android:layout_marginStart="54dp"
		android:layout_marginTop="27dp"
		android:layout_marginEnd="41dp"
		android:layout_marginBottom="502dp"
		android:fontFamily="@font/jetbrains_mono_medium"
		android:text="Submit Pictures to identify a plant"
		android:textSize="34sp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintHorizontal_bias="0.428"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintVertical_bias="0.048" />

	<Button
		android:id="@+id/flowerButton"
		android:layout_width="189dp"
		android:layout_height="84dp"
		android:layout_marginStart="102dp"
		android:layout_marginTop="293dp"
		android:layout_marginEnd="120dp"
		android:layout_marginBottom="354dp"
		android:text="Photo of Flower"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />

	<Button
		android:id="@+id/leavesButton"
		android:layout_width="184dp"
		android:layout_height="68dp"
		android:layout_marginStart="109dp"
		android:layout_marginTop="413dp"
		android:layout_marginEnd="118dp"
		android:layout_marginBottom="250dp"
		android:text="Photo of Leaves"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />

	<Button
		android:id="@+id/submitButton"
		android:layout_width="141dp"
		android:layout_height="87dp"
		android:layout_marginStart="135dp"
		android:layout_marginTop="576dp"
		android:layout_marginEnd="135dp"
		android:layout_marginBottom="68dp"
		android:text="Submit"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent" />

	<ImageButton
		android:id="@+id/infoButton"
		android:layout_width="66dp"
		android:layout_height="60dp"
		android:layout_marginStart="339dp"
		android:layout_marginTop="655dp"
		android:layout_marginEnd="6dp"
		android:layout_marginBottom="16dp"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintTop_toTopOf="parent"
		app:srcCompat="@android:drawable/ic_dialog_info" />

</androidx.constraintlayout.widget.ConstraintLayout>